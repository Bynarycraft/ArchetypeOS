{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Next Dev Server",
			"type": "shell",
			"command": "npm",
			"windows": {
				"command": "npm.cmd"
			},
			"args": [
				"--prefix",
				"${workspaceFolder}",
				"run",
				"dev"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": "build",
			"isBackground": true
		}
	]
}